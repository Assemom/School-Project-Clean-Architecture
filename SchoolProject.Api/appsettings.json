{
  "ConnectionStrings": {
    "Defaultconnection": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "ApplicationName": "School Project"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "",
    "Issuer": "SchoolSystemApp",
    "Audience": "SchoolSystemApp user",
    "ExpiresIn": 30
  },
  "MailSettings": {
    "Mail": "",
    "DisplayName": "School System",
    "Password": "",
    "Host": "smtp.gmail.com",
    "Port": 587
  }

}
